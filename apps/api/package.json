{
  "name": "@i-itsm/api",
  "version": "0.1.0",
  "private": true,
  "description": "I-ITSM Backend API (Express + MongoDB + BullMQ)",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
